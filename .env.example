APP_NAME=tekomata
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# tekomata Go API — the single backend surface (data, auth, metering).
# All app data flows through this; there is no local product DB.
TEKOMATA_API_URL=http://127.0.0.1:8080
TEKOMATA_API_TIMEOUT=10          # hard cap per request (seconds)
TEKOMATA_API_CONNECT_TIMEOUT=5   # connection establishment cap (seconds)
TEKOMATA_API_RETRIES=2           # bounded retries on transient (5xx / connection) errors
TEKOMATA_API_RETRY_SLEEP_MS=200  # base backoff between retries (doubles each attempt)

# Platform-admin key (X-Admin-Key) for the tekomata-internal admin endpoints used
# by /internal screens (FX rate sync; future plan/promo/feature-price CRUD). Sent
# as a header, NOT a tenant JWT — tekomata-owned, never per-company. Empty = those
# admin calls degrade to a friendly "not configured" state instead of erroring.
TEKOMATA_ADMIN_KEY=

# Internal staff area (/internal/*) — comma-separated email allowlist. Empty =
# nobody is staff (deny-by-default). Stop-gap until the API exposes a staff claim.
TEKOMATA_INTERNAL_EMAILS=
